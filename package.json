{
  "name": "cycling-routes",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "npm run readme:update",
    "build": "ng build",
    "readme:update": "python update_readme.py",
    "routes:update": "python update_routes.py && npm run readme:update",
    "routes:update:copy": "python update_routes.py --generate-descriptions && npm run readme:update",
    "routes:preview": "python update_routes.py --dry-run",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "prebuild:gh-pages": "npm run readme:update",
    "build:gh-pages": "ng build --configuration=github-pages",
    "deploy": "npm run build:gh-pages && npx gh-pages -d dist/cycling-routes/browser"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@primeng/themes": "^21.0.4",
    "less": "^4.6.4",
    "primeicons": "^7.0.0",
    "primeng": "^19.1.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@types/jasmine": "~5.1.0",
    "gh-pages": "^6.3.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}
